{
  "name": "kookly",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "env-cmd -f .env.local turbo run dev --filter=dashboard",
    "dev:convex": "convex dev --typecheck disable --tail-logs disable",
    "translate": "env-cmd -f .env.local turbo run translate",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prettier": "^3.7.4",
    "turbo": "^2.8.20",
    "typescript": "5.9.2",
    "env-cmd": "^11.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@convex-dev/better-auth": "0.11.2",
    "better-auth": "1.5.3",
    "convex": "1.34.0",
    "uploadthing": "^7.7.4"
  }
}
